OLLAMA_MODEL=phi3:mini
OLLAMA_FAST_MODEL=tinyllama
OLLAMA_URL=http://localhost:11434

# LLM_PROVIDER selects which backend call_llm() uses: "ollama" (local, free) or
# "openrouter" (hosted, may cost money depending on the model).
LLM_PROVIDER=ollama
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_FAST_MODEL=google/gemma-4-26b-a4b-it:free

DB_PATH=data/stocks.db
